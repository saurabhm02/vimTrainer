# Supabase: use shared pooler (IPv4), not direct db.* host (IPv6).
# Example: postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=postgres://vimtrainer:vimtrainer@localhost:5432/vimtrainer?sslmode=disable
JWT_SECRET=change-me-to-at-least-32-random-characters-here
CORS_ALLOWED_ORIGINS=http://localhost:5173
PORT=8080
ENVIRONMENT=development
LOG_LEVEL=debug
STORAGE_PROVIDER=local
STORAGE_PATH=/tmp/vimtrainer-uploads
